@startuml
title Three-tier Architecture for Food Delivery Website

package "Presentation Layer (Frontend)" {
   [HTML5]
   [CSS3]
   [JavaScript ES6+]
   [Bootstrap 5.3]
   note right of [HTML5]
     Semantic markup
     Schema.org microdata
     Responsive design
   end note
 }

 package "Business Logic Layer (Backend)" {
   [PHP 8.0 (OOP)]
   [Classes: Database, Cart, Order, Auth, MenuItem, Category]
   [AJAX API endpoints]
   [Data validation]
   [Session management]
   note right of [PHP 8.0 (OOP)]
     Singleton pattern
     PDO prepared statements
     Two-level validation
   end note
 }

 package "Data Layer (Database)" {
   [MySQL 8.0]
   [InnoDB transactions]
   [Tables: categories, menu_items, clients, placed_orders, in_order, reservations]
   note right of [MySQL 8.0]
     Relational model
     Foreign keys
     Index optimization
   end note
 }

 [HTML5] --> [PHP 8.0 (OOP)]
 [CSS3] --> [PHP 8.0 (OOP)]
 [JavaScript ES6+] --> [PHP 8.0 (OOP)]
 [Bootstrap 5.3] --> [PHP 8.0 (OOP)]

 [PHP 8.0 (OOP)] --> [MySQL 8.0]
 [Classes: Database, Cart, Order, Auth, MenuItem, Category] --> [MySQL 8.0]
 [AJAX API endpoints] --> [MySQL 8.0]
 [Session management] --> [MySQL 8.0]

@enduml

@startuml
title ER Diagram

entity categories {
   id : INT
   name : VARCHAR
   description : TEXT
   image_icon : VARCHAR
   sort_order : INT
 }

entity menu_items {
   id : INT
   category_id : INT
   name : VARCHAR
   description : TEXT
   price : DECIMAL
   weight : INT
   image_url : VARCHAR
   is_available : BOOLEAN
   is_hit : BOOLEAN
   created_at : TIMESTAMP
 }

entity clients {
   id : INT
   phone : VARCHAR
   name : VARCHAR
   email : VARCHAR
   total_orders_sum : DECIMAL
   bonus_points : INT
   created_at : TIMESTAMP
 }

entity placed_orders {
   id : INT
   client_id : INT
   order_date : DATETIME
   delivery_address : VARCHAR
   delivery_date : DATE
   delivery_time : TIME
   total_sum : DECIMAL
   delivery_cost : DECIMAL
   status : VARCHAR
   courier_comment : TEXT
   created_at : TIMESTAMP
 }

entity in_order {
   order_id : INT
   menu_item_id : INT
   quantity : INT
   price_at_time : DECIMAL
 }

entity reservations {
   id : INT
   client_name : VARCHAR
   client_phone : VARCHAR
   reservation_date : DATE
   reservation_time : TIME
   persons_count : INT
   comment : TEXT
   status : VARCHAR
   created_at : TIMESTAMP
 }

 categories ||--o{ menu_items : contains
 clients ||--o{ placed_orders : makes
 placed_orders ||--o{ in_order : has
 menu_items ||--o{ in_order : included_in
 clients ||--o{ reservations : creates

@enduml
