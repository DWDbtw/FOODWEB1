@startuml
title Food Delivery Website Use Case Diagram

actor "Customer (Guest)" as Customer
 actor "Manager" as Manager
 actor "Administrator" as Admin

 rectangle "Public Website" {
   usecase "Browse Menu (UC1)" as UC1
   usecase "Manage Cart (UC2)" as UC2
   usecase "Place Order (UC3)" as UC3
   usecase "View Order History (UC4)" as UC4
   usecase "Reserve Table (UC5)" as UC5
 }

 rectangle "Admin Panel - Manager" {
   usecase "Authenticate (UC10)" as UC10
   usecase "Manage Orders (UC6)" as UC6
   usecase "View Customer Orders (UC4_m)" as UC4_m
 }

 rectangle "Admin Panel - Administrator" {
   usecase "Manage Menu (UC7)" as UC7
   usecase "Manage Customers (UC8)" as UC8
   usecase "Generate Reports (UC9)" as UC9
 }

 Customer --> UC1
 Customer --> UC2
 Customer --> UC3
 Customer --> UC5

 Manager --> UC10
 Manager --> UC6
 Manager --> UC4_m

 Admin --> UC10
 Admin --> UC6
 Admin --> UC4_m
 Admin --> UC7
 Admin --> UC8
 Admin --> UC9

 UC1 .> UC2 : <<extend>>
 UC3 .> UC10 : <<include>>
 UC6 .> UC4_m : <<include>>

@enduml

